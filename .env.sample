# Chave da API do Groq (OBRIGATORIO).
# Cadastro gratuito em: https://console.groq.com/keys
GROQ_API_KEY=

# Segredo usado para assinar os JWTs emitidos pelo /api/v1/auth/token
# (OBRIGATORIO). Use uma string aleatoria com no minimo 32 caracteres.
# Gere uma com:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# NUNCA compartilhe ou commite este valor.
JWT_SECRET=

# Tempo de vida dos JWTs em segundos (OPCIONAL, default 3600 = 1 hora).
JWT_EXPIRA_SEGUNDOS=3600
